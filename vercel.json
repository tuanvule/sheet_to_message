{
  "version": 2,
  "builds": [
    {
      "src": "src/index.ts", 
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "src/function/**", 
          "public/**"         
        ]
      }
    }
    
    
  ],
  "routes": [
    
    
    {
      "src": "/(.*)",
      "dest": "src/index.ts"
    }
    
    
  ],
  "outputDirectory": "dist" 
}